# E2E Test Environment Variables

# Test user credentials
E2E_TEST_EMAIL=test-e2e@example.com
E2E_TEST_PASSWORD=test-password-123
E2E_TEST_NAME=E2E Test User

# Base URL for tests (defaults to http://localhost:3000)
E2E_BASE_URL=http://localhost:3000

# Database URL for test environment (if needed)
# DATABASE_URL="file:./test.db"

# NextAuth secret (should match your development/production secret)
# NEXTAUTH_SECRET=your-secret-key-here