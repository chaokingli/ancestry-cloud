# ============================================
# Docker Environment Variables Template
# ============================================
# Copy this file to .env and update values before running in production

# ============================================
# NextAuth.js Configuration
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-32-byte-random-secret-key-here

# ============================================
# Database Configuration (SQLite)
# ============================================
# The database path in Docker must be a full path
# We mount a volume to /data/db so the database persists
DATABASE_URL=file:/data/db/dev.db

# ============================================
# Next.js Configuration
# ============================================
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Disable Next.js telemetry (recommended for production)
NEXT_TELEMETRY_DISABLED=1

# ============================================
# Optional: CustomDomain for NextAuth
# ============================================
# If deploying with a custom domain:
# NEXTAUTH_URL=https://yourdomain.com
# NEXTAUTH_URL_INTERNAL=http://localhost:3000
